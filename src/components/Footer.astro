<style>
.footer-vm {
  background: #050505;
  padding: 80px 0 0;
  border-top: 4px solid var(--yellow);
}
.foot-top {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1.3fr;
  gap: 50px;
  padding: 0 20px 50px;
}
.foot-col { min-width: 0; }
.foot-logo img { max-height: 80px; width: auto; margin-bottom: 16px; }
.foot-about {
  font-size: 0.78rem;
  line-height: 1.6;
  color: var(--dim);
  margin-bottom: 22px;
  max-width: 340px;
}
.foot-address {
  display: flex; flex-direction: column; gap: 8px;
  margin-bottom: 18px;
  font-size: 0.74rem;
  line-height: 1.5;
}
.foot-address .k {
  color: var(--dim);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  display: block;
}
.foot-address .v { color: var(--fg); }

.foot-social { display: flex; gap: 10px; }
.foot-social a {
  width: 44px; height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,215,0,0.06);
  border: 1px solid rgba(255,215,0,0.28);
  color: var(--yellow);
  transition: background 0.2s, color 0.2s;
}
.foot-social a:hover {
  background: var(--yellow);
  color: var(--bg);
}

.foot-title {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255,215,0,0.2);
}
.foot-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.foot-links li, .foot-links a {
  font-size: 0.78rem;
  color: var(--dim);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.foot-links a:hover { color: var(--yellow); }
.foot-links .ic { color: var(--yellow); font-size: 0.7rem; }
.foot-hours {
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px dashed rgba(255,255,255,0.1);
  font-size: 0.72rem;
  color: var(--dim);
  line-height: 1.6;
}

.foot-certs {
  background: #020202;
  padding: 22px 0;
  border-top: 1px solid var(--grid);
  border-bottom: 1px solid var(--grid);
}
.foot-certs-inner {
  display: flex;
  align-items: center;
  gap: 18px;
  flex-wrap: wrap;
  padding: 0 20px;
}
.fcb-title {
  font-size: 0.68rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--fg);
  padding-right: 20px;
  border-right: 2px solid rgba(255,215,0,0.25);
}
.fcb-list { display: flex; flex-wrap: wrap; gap: 8px; }
.fcb-chip {
  font-size: 0.68rem;
  padding: 6px 10px;
  color: #FAFAFA;
  background: rgba(255,215,0,0.05);
  border: 1px solid rgba(255,215,0,0.4);
  letter-spacing: 0.1em;
}

.foot-bottom {
  padding: 22px 20px;
  background: #000;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
  font-size: 0.64rem;
  letter-spacing: 0.14em;
  color: var(--dim);
  text-transform: uppercase;
}

/* WhatsApp FAB */
.wa-fab {
  position: fixed;
  right: 16px; bottom: 16px;
  z-index: 99;
  background: #25D366;
  color: #fff !important;
  padding: 14px 20px;
  border-radius: 50px;
  font-size: 0.82rem;
  font-weight: 700;
  box-shadow: 0 6px 24px rgba(37,211,102,0.4);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: transform 0.2s;
}
.wa-fab:hover { transform: scale(1.04); }

@media (max-width: 1000px) {
  .foot-top { grid-template-columns: 1fr 1fr; gap: 40px; padding: 0 18px 40px; }
}
@media (max-width: 600px) {
  .footer-vm { padding: 50px 0 0; }
  .foot-top { grid-template-columns: 1fr; gap: 36px; }
  .foot-certs-inner { flex-direction: column; align-items: flex-start; }
  .fcb-title { border-right: none; border-bottom: 2px solid rgba(255,215,0,0.25); padding: 0 0 10px; width: 100%; }
  .foot-bottom { flex-direction: column; align-items: flex-start; padding: 18px; }
  .wa-fab span { display: none; }
  .wa-fab { padding: 14px; border-radius: 50%; }
}
</style>
