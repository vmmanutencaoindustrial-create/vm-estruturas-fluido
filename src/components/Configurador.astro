---
// Configurador de galpão — sliders + preview 2D SVG (instantâneo) + 3D lazy on-demand
---
<section id="configurador" class="cfg-section" aria-label="Configurador de galpão">
  <div class="cfg-head container">
    <div>
      <div class="tag mono">[05] CONFIGURADOR · MONTE SEU PROJETO</div>
      <h2 class="bebas">Monte seu<br>projeto agora.</h2>
    </div>
    <p class="mono">Ajuste metragem, pé-direito, cobertura e opcionais. Veja a estrutura sendo desenhada em tempo real e envie a configuração direto pro nosso engenheiro. <b class="y">Do mezanino de 50m² ao galpão de 5.000m²</b> — pequenas, médias e grandes estruturas.</p>
  </div>

  <div class="cfg-shortcut container mono">
    <span class="cs-label">Não quer montar agora?</span>
    <a class="cs-btn" href="https://wa.me/5511972328541?text=Ol%C3%A1!%20Cheguei%20pelo%20site%20da%20VM%20Estruturas%20Met%C3%A1licas%20e%20quero%20saber%20mais%20sobre%20os%20servi%C3%A7os.%20Pode%20me%20orientar%3F" target="_blank" rel="noopener">
      ► QUERO SABER MAIS SOBRE ESTRUTURAS METÁLICAS
    </a>
  </div>

  <div class="cfg-main">
    <aside class="cfg-controls">
      <h3 class="bebas cfg-ctitle">Controles</h3>
      <p class="cfg-csub mono">AJUSTE, VEJA, SOLICITE</p>

      <!-- Tipo de projeto -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>TIPO DE PROJETO</span></div>
        <div class="seg" id="segProjeto">
          <button class="on" data-val="galpao" type="button">Galpão completo</button>
          <button data-val="cobertura" type="button">Cobertura</button>
          <button data-val="mezanino" type="button">Mezanino</button>
          <button data-val="marquise" type="button">Marquise</button>
        </div>
      </div>

      <!-- Comprimento -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>COMPRIMENTO</span><span class="val bebas" id="valComp">40 m</span></div>
        <input type="range" id="comp" min="10" max="100" step="5" value="40" aria-label="Comprimento em metros">
      </div>

      <!-- Largura -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>LARGURA</span><span class="val bebas" id="valLarg">20 m</span></div>
        <input type="range" id="larg" min="6" max="50" step="2" value="20" aria-label="Largura em metros">
      </div>

      <!-- Pé-direito -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>PÉ-DIREITO</span></div>
        <div class="seg seg-small" id="segPe">
          <button data-val="4" type="button">4 m</button>
          <button data-val="6" type="button">6 m</button>
          <button class="on" data-val="8" type="button">8 m</button>
          <button data-val="10" type="button">10 m</button>
          <button data-val="12" type="button">12 m</button>
        </div>
      </div>

      <!-- Cobertura -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>COBERTURA</span></div>
        <div class="seg seg-two" id="segCob">
          <button class="on" data-val="tp40" type="button">TP40 sanduíche</button>
          <button data-val="tp25" type="button">Trapezoidal simples</button>
          <button data-val="zipada" type="button">Zíper standing seam</button>
          <button data-val="transl" type="button">Policarbonato</button>
        </div>
      </div>

      <!-- Opcionais -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>⬥ ESTRUTURA ADICIONAL</span></div>
        <div class="toggles" id="toggles">
          <label class="toggle"><input type="checkbox" data-ex="mezanino"><span class="check"></span><span class="toggle-name">Mezanino Steel Deck</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="doca"><span class="check"></span><span class="toggle-name">Doca de carga</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="escrit"><span class="check"></span><span class="toggle-name">Escritório anexo</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="ponte"><span class="check"></span><span class="toggle-name">Ponte rolante (até 20t)</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="cabine"><span class="check"></span><span class="toggle-name">Cabine primária</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="fotovolt"><span class="check"></span><span class="toggle-name">Usina solar fotovoltaica</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="sprinkler"><span class="check"></span><span class="toggle-name">Sprinklers combate incêndio</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
          <label class="toggle"><input type="checkbox" data-ex="piso"><span class="check"></span><span class="toggle-name">Piso polido epóxi industrial</span><span class="toggle-price mono">◉ OPCIONAL</span></label>
        </div>
      </div>

      <!-- CEP -->
      <div class="ctrl-group">
        <div class="ctrl-label mono"><span>CIDADE / CEP</span></div>
        <input id="cep" type="text" placeholder="Ex: Barueri / 06451-000" autocomplete="postal-code" />
      </div>
    </aside>

    <!-- Preview -->
    <div class="cfg-viz-wrap">
      <div class="cfg-viz">
        <div class="cfg-viz-meta mono">
          <span><span class="y">■ PREVIEW AO VIVO</span></span>
          <span id="vizSize">40 × 20 × 8 m</span>
        </div>

        <!-- SVG visualização 2D — leve, instantâneo -->
        <svg class="galpao-svg" id="galpaoSvg" viewBox="0 0 900 500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"></svg>

        <div class="cfg-viz-tips mono">
          <span><span class="y">►</span> MEDIDAS EM TEMPO REAL</span>
          <button id="btn3d" class="btn3d" type="button">⬢ VER EM 3D</button>
        </div>
      </div>

      <!-- Output/Resultado -->
      <div class="cfg-output">
        <div class="out-block">
          <div class="k mono">ÁREA CONSTRUÍDA</div>
          <div class="v bebas" id="outArea">800 m²</div>
          <div class="sub mono" id="outAreaSub">40 × 20 m</div>
        </div>
        <div class="out-block">
          <div class="k mono">PESO DE AÇO</div>
          <div class="v bebas" id="outAco">32 t</div>
          <div class="sub mono">40 kg/m²</div>
        </div>
        <div class="out-block">
          <div class="k mono">PRAZO</div>
          <div class="v bebas" id="outPrazo">90 dias</div>
          <div class="sub mono">projeto + fabricação + montagem</div>
        </div>

        <!-- CTAs -->
        <div class="cta-row">
          <a class="btn-cfg fill" href="#" id="btnEnviarProjeto">► ENVIAR PROJETO PELO WHATSAPP</a>
          <a class="btn-cfg line" href="#" id="btnSave">⎘ SALVAR LINK</a>
        </div>

        <p class="cfg-disclaimer mono">
          ■ <b class="y">Orçamento sob medida:</b> Cada projeto é único — logística, fundação, acesso e escopo definem o investimento. Nosso engenheiro analisa sua configuração e envia <b>proposta técnica completa em até 24h úteis</b>. Fazemos <b>do mezanino de 50m² ao galpão de 5.000m²</b>.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Modal 3D (lazy — Three.js só carrega ao clicar em "Ver em 3D") -->
<div class="maquete-modal" id="maqueteModal" aria-hidden="true">
  <div class="maquete-topbar mono">
    <span><span class="y">⬢</span> MAQUETE 3D · VISUALIZAÇÃO INTERATIVA</span>
    <span id="maqueteSpec">40 × 20 × 8 m · 800 m²</span>
    <button class="close mono" id="maqueteClose" type="button">✕ FECHAR</button>
  </div>
  <div class="maquete-canvas-wrap">
    <canvas id="maqueteCanvas"></canvas>
    <div class="maquete-loading mono" id="maqueteLoading">► CARREGANDO MAQUETE 3D...</div>
  </div>
</div>

<script>
  // Configurador — lógica pura sem GSAP, visualização 2D via SVG inline
  (function () {
    const state = {
      projeto: 'galpao',
      comp: 40,
      larg: 20,
      pe: 8,
      cob: 'tp40',
      extras: {
        mezanino: false, doca: false, escrit: false, ponte: false,
        cabine: false, fotovolt: false, sprinkler: false, piso: false
      },
      cep: ''
    };

    const COB_LABEL: Record<string, string> = {
      tp25: 'Trapezoidal simples',
      tp40: 'TP40 sanduíche c/ PU',
      transl: 'Policarbonato translúcida',
      zipada: 'Zíper standing seam'
    };

    function calc() {
      const area = state.comp * state.larg;
      const mult = { galpao: 1, cobertura: 0.6, mezanino: 0.8, marquise: 0.5 }[state.projeto] || 1;
      const peso = Math.round(area * 40 * mult / 1000 * 10) / 10;
      let prazo = 120;
      if (area < 400) prazo = 60;
      else if (area < 1000) prazo = 90;
      else if (area < 2500) prazo = 120;
      else prazo = 150;
      return { area, peso, prazo };
    }

    function update() {
      const r = calc();
      const set = (id: string, v: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = v;
      };
      set('valComp', state.comp + ' m');
      set('valLarg', state.larg + ' m');
      set('vizSize', `${state.comp} × ${state.larg} × ${state.pe} m`);
      set('outArea', r.area.toLocaleString('pt-BR') + ' m²');
      set('outAreaSub', `${state.comp} × ${state.larg} m`);
      set('outAco', r.peso + ' t');
      set('outPrazo', r.prazo + ' dias');
      const ms = document.getElementById('maqueteSpec');
      if (ms) ms.textContent = `${state.comp} × ${state.larg} × ${state.pe} m · ${r.area} m²`;
      renderSvg();
    }

    // Renderiza galpão em SVG 2D (leve, instantâneo)
    function renderSvg() {
      const svg = document.getElementById('galpaoSvg');
      if (!svg) return;
      const w = state.comp * 6;
      const h = state.pe * 8;
      const d = state.larg * 4;
      const cx = 450, cy = 280;
      const svgNS = 'http://www.w3.org/2000/svg';

      // Isométrica simples
      const pts = {
        frontBL: [cx - w/2, cy + h/2],
        frontBR: [cx + w/2, cy + h/2],
        frontTL: [cx - w/2, cy - h/2],
        frontTR: [cx + w/2, cy - h/2],
        backBL:  [cx - w/2 + d*0.7, cy + h/2 - d*0.3],
        backBR:  [cx + w/2 + d*0.7, cy + h/2 - d*0.3],
        backTL:  [cx - w/2 + d*0.7, cy - h/2 - d*0.3],
        backTR:  [cx + w/2 + d*0.7, cy - h/2 - d*0.3],
        roofFront: [cx, cy - h/2 - 40],
        roofBack:  [cx + d*0.7, cy - h/2 - 40 - d*0.3]
      };
      svg.innerHTML = `
        <defs>
          <linearGradient id="wall" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#4a4a4a"/>
            <stop offset="1" stop-color="#2a2a2a"/>
          </linearGradient>
          <linearGradient id="side" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0" stop-color="#3a3a3a"/>
            <stop offset="1" stop-color="#1a1a1a"/>
          </linearGradient>
        </defs>
        <!-- Chão -->
        <polygon points="${pts.frontBL[0]},${pts.frontBL[1]} ${pts.frontBR[0]},${pts.frontBR[1]} ${pts.backBR[0]},${pts.backBR[1]} ${pts.backBL[0]},${pts.backBL[1]}" fill="#1a1a1a" stroke="#FFD700" stroke-width="1" opacity="0.4"/>
        <!-- Parede lateral -->
        <polygon points="${pts.frontBR[0]},${pts.frontBR[1]} ${pts.frontTR[0]},${pts.frontTR[1]} ${pts.backTR[0]},${pts.backTR[1]} ${pts.backBR[0]},${pts.backBR[1]}" fill="url(#side)" stroke="#FFD700" stroke-width="1.5"/>
        <!-- Parede frontal -->
        <polygon points="${pts.frontBL[0]},${pts.frontBL[1]} ${pts.frontBR[0]},${pts.frontBR[1]} ${pts.frontTR[0]},${pts.frontTR[1]} ${pts.frontTL[0]},${pts.frontTL[1]}" fill="url(#wall)" stroke="#FFD700" stroke-width="2"/>
        <!-- Telhado -->
        <polygon points="${pts.frontTL[0]},${pts.frontTL[1]} ${pts.frontTR[0]},${pts.frontTR[1]} ${pts.roofFront[0] + 30},${pts.roofFront[1]} ${pts.roofFront[0] - 30},${pts.roofFront[1]}" fill="#2a2a2a" stroke="#FFD700" stroke-width="2"/>
        <polygon points="${pts.frontTR[0]},${pts.frontTR[1]} ${pts.backTR[0]},${pts.backTR[1]} ${pts.roofBack[0]},${pts.roofBack[1]} ${pts.roofFront[0] + 30},${pts.roofFront[1]}" fill="#3a3a3a" stroke="#FFD700" stroke-width="1.5"/>
        <!-- Portão -->
        <rect x="${cx - 20}" y="${cy + h/2 - 60}" width="40" height="60" fill="#FFD700" opacity="0.8" stroke="#FFD700" stroke-width="1.5"/>
        <!-- Faixa de medida -->
        <line x1="${pts.frontBL[0]}" y1="${pts.frontBL[1] + 20}" x2="${pts.frontBR[0]}" y2="${pts.frontBR[1] + 20}" stroke="#FFD700" stroke-width="1.5"/>
        <text x="${cx}" y="${pts.frontBL[1] + 40}" text-anchor="middle" fill="#FFD700" font-family="'JetBrains Mono',monospace" font-size="14" font-weight="700">${state.comp} m</text>
        <line x1="${pts.frontTR[0] + 25}" y1="${pts.frontTR[1]}" x2="${pts.frontBR[0] + 25}" y2="${pts.frontBR[1]}" stroke="#FFD700" stroke-width="1.5"/>
        <text x="${pts.frontBR[0] + 35}" y="${cy + 5}" fill="#FFD700" font-family="'JetBrains Mono',monospace" font-size="14" font-weight="700">${state.pe} m</text>
      `;
    }

    // Listeners
    document.querySelectorAll<HTMLButtonElement>('#segProjeto button').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('#segProjeto button').forEach(x => x.classList.remove('on'));
        b.classList.add('on');
        state.projeto = b.dataset.val!;
        update();
      });
    });
    document.querySelectorAll<HTMLButtonElement>('#segPe button').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('#segPe button').forEach(x => x.classList.remove('on'));
        b.classList.add('on');
        state.pe = +b.dataset.val!;
        update();
      });
    });
    document.querySelectorAll<HTMLButtonElement>('#segCob button').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('#segCob button').forEach(x => x.classList.remove('on'));
        b.classList.add('on');
        state.cob = b.dataset.val!;
        update();
      });
    });
    const compInput = document.getElementById('comp') as HTMLInputElement;
    const largInput = document.getElementById('larg') as HTMLInputElement;
    const cepInput = document.getElementById('cep') as HTMLInputElement;
    compInput?.addEventListener('input', e => { state.comp = +(e.target as HTMLInputElement).value; update(); });
    largInput?.addEventListener('input', e => { state.larg = +(e.target as HTMLInputElement).value; update(); });
    cepInput?.addEventListener('input', e => { state.cep = (e.target as HTMLInputElement).value; });
    document.querySelectorAll<HTMLInputElement>('#toggles input').forEach(inp => {
      inp.addEventListener('change', () => {
        const key = inp.dataset.ex!;
        (state.extras as any)[key] = inp.checked;
      });
    });

    // Monta resumo + WhatsApp
    function buildSummary() {
      const r = calc();
      const tipoLabel: Record<string, string> = {
        galpao: 'Galpão completo', cobertura: 'Cobertura metálica',
        mezanino: 'Mezanino', marquise: 'Marquise'
      };
      const cobLabel = COB_LABEL[state.cob] || state.cob;
      const extrasAtivos = Object.entries(state.extras).filter(([k,v]) => v).map(([k]) => k);
      const extrasLabel: Record<string, string> = {
        mezanino: 'Mezanino Steel Deck', doca: 'Doca de carga',
        escrit: 'Escritório anexo', ponte: 'Ponte rolante',
        cabine: 'Cabine primária', fotovolt: 'Usina solar',
        sprinkler: 'Sprinklers', piso: 'Piso polido epóxi'
      };
      const linhas = [
        'Olá! Montei meu projeto no configurador do site da VM:',
        '',
        `▸ Tipo: ${tipoLabel[state.projeto]}`,
        `▸ Dimensões: ${state.comp} × ${state.larg} m (${r.area} m²)`,
        `▸ Pé-direito: ${state.pe} m`,
        `▸ Cobertura: ${cobLabel}`,
        `▸ Peso estimado: ${r.peso} t`,
        `▸ Prazo estimado: ${r.prazo} dias`
      ];
      if (state.cep) linhas.push(`▸ Local: ${state.cep}`);
      if (extrasAtivos.length) {
        linhas.push('', 'Opcionais:');
        extrasAtivos.forEach(k => linhas.push(`  • ${extrasLabel[k]}`));
      }
      linhas.push('', 'Gostaria de receber o orçamento técnico. Aguardo contato!');
      return linhas.join('\n');
    }

    document.getElementById('btnEnviarProjeto')?.addEventListener('click', e => {
      e.preventDefault();
      const msg = buildSummary();
      window.open('https://wa.me/5511972328541?text=' + encodeURIComponent(msg), '_blank', 'noopener');
    });

    document.getElementById('btnSave')?.addEventListener('click', e => {
      e.preventDefault();
      const url = new URL(window.location.href);
      url.searchParams.set('comp', String(state.comp));
      url.searchParams.set('larg', String(state.larg));
      url.searchParams.set('pe', String(state.pe));
      url.searchParams.set('tipo', state.projeto);
      url.searchParams.set('cob', state.cob);
      Object.entries(state.extras).forEach(([k,v]) => { if (v) url.searchParams.set(k, '1'); });
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url.toString()).then(() => {
          const btn = e.target as HTMLElement;
          btn.textContent = '✓ LINK COPIADO';
          setTimeout(() => btn.textContent = '⎘ SALVAR LINK', 2000);
        });
      }
    });

    // ═══ Lazy-load Three.js quando clicar "Ver em 3D" ═══
    const modal = document.getElementById('maqueteModal') as HTMLElement;
    const modalClose = document.getElementById('maqueteClose');
    let threeLoaded = false;

    document.getElementById('btn3d')?.addEventListener('click', async () => {
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      if (threeLoaded) return;

      try {
        // Carrega Three.js via bare imports (resolvidos pelo importmap do Base.astro)
        // /* @vite-ignore */ garante que Vite não tente resolver no build
        const THREE = await import(/* @vite-ignore */ 'three');
        const OrbitModule = await import(/* @vite-ignore */ 'three/addons/controls/OrbitControls.js');
        threeLoaded = true;
        initThreeScene(THREE, OrbitModule.OrbitControls);
      } catch (err) {
        console.error('[VM 3D] carregar falhou:', err);
        const loading = document.getElementById('maqueteLoading');
        if (loading) loading.textContent = '⚠ Não foi possível carregar o 3D: ' + (err instanceof Error ? err.message : String(err));
      }
    });

    modalClose?.addEventListener('click', () => {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
    });

    function initThreeScene(THREE: any, OrbitControls: any) {
      const canvas = document.getElementById('maqueteCanvas') as HTMLCanvasElement;
      const loading = document.getElementById('maqueteLoading');
      if (!canvas) return;

      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x1a1a1a);
      const camera = new THREE.PerspectiveCamera(50, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
      camera.position.set(60, 30, 60);

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setSize(canvas.clientWidth, canvas.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const controls = new OrbitControls(camera, canvas);
      controls.enableDamping = true;
      controls.dampingFactor = 0.08;

      // Luzes
      scene.add(new THREE.AmbientLight(0xffffff, 0.6));
      const dl = new THREE.DirectionalLight(0xffffff, 0.9);
      dl.position.set(30, 50, 30);
      scene.add(dl);

      // Galpão
      const comp = state.comp, larg = state.larg, pe = state.pe;
      const group = new THREE.Group();
      // Piso
      const piso = new THREE.Mesh(
        new THREE.BoxGeometry(comp + 2, 0.3, larg + 2),
        new THREE.MeshStandardMaterial({ color: 0x666666, roughness: 0.9 })
      );
      piso.position.y = -0.15;
      group.add(piso);
      // 4 paredes
      const wallMat = new THREE.MeshStandardMaterial({ color: 0x4a4a4a, roughness: 0.7 });
      const wF = new THREE.Mesh(new THREE.BoxGeometry(comp, pe, 0.15), wallMat);
      wF.position.set(0, pe/2, larg/2); group.add(wF);
      const wB = new THREE.Mesh(new THREE.BoxGeometry(comp, pe, 0.15), wallMat);
      wB.position.set(0, pe/2, -larg/2); group.add(wB);
      const wL = new THREE.Mesh(new THREE.BoxGeometry(0.15, pe, larg), wallMat);
      wL.position.set(-comp/2, pe/2, 0); group.add(wL);
      const wR = new THREE.Mesh(new THREE.BoxGeometry(0.15, pe, larg), wallMat);
      wR.position.set(comp/2, pe/2, 0); group.add(wR);
      // Telhado prismático
      const roofH = larg * 0.15;
      const roofShape = new THREE.Shape();
      roofShape.moveTo(-larg/2, 0);
      roofShape.lineTo(larg/2, 0);
      roofShape.lineTo(0, roofH);
      roofShape.lineTo(-larg/2, 0);
      const roofGeo = new THREE.ExtrudeGeometry(roofShape, { depth: comp, bevelEnabled: false });
      const roof = new THREE.Mesh(roofGeo, new THREE.MeshStandardMaterial({ color: 0x1a1a1a, roughness: 0.5, metalness: 0.3 }));
      roof.rotation.y = Math.PI / 2;
      roof.position.set(-comp/2, pe, 0);
      group.add(roof);
      // Faixa amarela
      const faixa = new THREE.Mesh(
        new THREE.BoxGeometry(comp + 0.1, 0.6, 0.16),
        new THREE.MeshStandardMaterial({ color: 0xFFD700, roughness: 0.4, metalness: 0.1 })
      );
      faixa.position.set(0, pe * 0.35, larg/2 + 0.02);
      group.add(faixa);

      scene.add(group);
      if (loading) loading.style.display = 'none';

      function animate() {
        requestAnimationFrame(animate);
        controls.update();
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', () => {
        camera.aspect = canvas.clientWidth / canvas.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(canvas.clientWidth, canvas.clientHeight);
      });
    }

    // Restaura do URL
    (function loadFromURL() {
      const p = new URL(window.location.href).searchParams;
      if (p.get('comp')) state.comp = +p.get('comp')!;
      if (p.get('larg')) state.larg = +p.get('larg')!;
      if (p.get('pe')) state.pe = +p.get('pe')!;
      if (p.get('tipo')) state.projeto = p.get('tipo')!;
      if (p.get('cob')) state.cob = p.get('cob')!;
      ['mezanino','doca','escrit','ponte','cabine','fotovolt','sprinkler','piso'].forEach(k => {
        if (p.get(k) === '1') (state.extras as any)[k] = true;
      });
      if (compInput) compInput.value = String(state.comp);
      if (largInput) largInput.value = String(state.larg);
    })();

    update();
  })();
</script>

