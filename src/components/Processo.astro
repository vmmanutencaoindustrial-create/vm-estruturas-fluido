---
const steps = [
  { num: '01', day: 'Dia 1–3', title: 'Visita técnica + briefing', desc: 'Engenheiro vai ao terreno. Mede, fotografa, tira dúvidas. Sai com escopo fechado e proposta em até 48h.' },
  { num: '02', day: 'Dia 4–14', title: 'Projeto executivo + ART', desc: 'Cálculo estrutural NBR 8800/14762, projeto 3D, memorial descritivo, ART registrada no CREA.' },
  { num: '03', day: 'Dia 15–60', title: 'Fabricação na planta', desc: 'Aço cortado, soldado e pintado com controle técnico rigoroso. Solda inspecionada por amostragem. Fotos diárias.' },
  { num: '04', day: 'Dia 61–105', title: 'Montagem em obra', desc: 'Equipe técnica com NR-18, NR-35 e PCMSO em dia. Içamento controlado, torque calibrado, prumo verificado. RDO toda sexta.' },
  { num: '05', day: 'Dia 106–120', title: 'Entrega + as-built', desc: 'Vistoria final, projeto as-built atualizado, manual de manutenção, garantia de 5 anos sobre estrutura e solda.' }
];
---
<section id="processo" class="processo-section">
  <div class="processo-head container">
    <div class="tag mono">[05] PROCESSO TÉCNICO</div>
    <h2 class="bebas">Da visita técnica<br><span class="y">à viga içada.</span></h2>
    <p class="mono">5 etapas auditáveis. Cronograma público. Você acompanha cada parafuso.</p>
  </div>

  <ol class="steps container">
    {steps.map(step => (
      <li class="step">
        <div class="step-num bebas">{step.num}</div>
        <div class="step-day mono">{step.day}</div>
        <h3 class="bebas">{step.title}</h3>
        <p class="mono">{step.desc}</p>
      </li>
    ))}
  </ol>
</section>

<style>
.processo-section {
  padding: 100px 0;
  background: #0a0a0a;
  border-top: 1px solid var(--grid);
}
.processo-head {
  text-align: center;
  margin-bottom: 60px;
}
.tag {
  font-size: 0.72rem;
  color: var(--yellow);
  letter-spacing: 0.24em;
  margin-bottom: 14px;
}
.processo-head h2 {
  font-size: clamp(2.2rem, 5vw, 4rem);
  line-height: 0.95;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.processo-head p {
  font-size: 0.92rem;
  color: rgba(250,250,250,0.65);
  max-width: 560px;
  margin: 0 auto;
}

.steps {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 18px;
}
.step {
  padding: 26px 22px;
  background: #141414;
  border-top: 3px solid var(--yellow);
  transform: translateZ(0);
}
.step-num {
  font-size: 2.4rem;
  color: var(--yellow);
  line-height: 1;
  margin-bottom: 8px;
}
.step-day {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  color: rgba(250,250,250,0.55);
  text-transform: uppercase;
  margin-bottom: 14px;
}
.step h3 {
  font-size: 1.25rem;
  line-height: 1.15;
  letter-spacing: 0.02em;
  margin-bottom: 10px;
}
.step p {
  font-size: 0.8rem;
  line-height: 1.55;
  color: rgba(250,250,250,0.65);
}

@media (max-width: 1100px) {
  .steps { grid-template-columns: repeat(2, 1fr); padding: 0 18px; }
}
@media (max-width: 500px) {
  .processo-section { padding: 60px 0; }
  .steps { grid-template-columns: 1fr; gap: 14px; }
  .step { padding: 22px 18px; }
}
</style>
