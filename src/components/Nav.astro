---
// Nav sticky — leve, sem JS
const base = import.meta.env.BASE_URL;
---
<nav class="vm-nav">
  <a href="#hero" class="logo" aria-label="VM Estruturas Metálicas">
    <img src={`${base}/assets/vm-logo.png`} alt="VM Estruturas Metálicas" width="48" height="31" />
    <span class="logo-text mono">VM · ESTRUTURAS</span>
  </a>
  <div class="nav-links mono">
    <a href="#cases">Projetos</a>
    <a href="#contato">Contato</a>
  </div>
  <a class="nav-tel mono" href="tel:+5511972328541" aria-label="Ligar (11) 9 7232-8541">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
      <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
    </svg>
    <span class="tel-txt">(11) 9 7232-8541</span>
  </a>
</nav>

<style>
.vm-nav {
  position: sticky; top: 0;
  z-index: 100;
  background: linear-gradient(180deg, rgba(10,10,10,0.95), rgba(10,10,10,0.75));
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  border-bottom: 1px solid rgba(255,215,0,0.1);
}
.logo {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--fg);
}
.logo img { height: 32px; width: auto; }
.logo-text {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--yellow);
}
.nav-links {
  display: flex;
  gap: 18px;
  font-size: 0.72rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.nav-links a { color: rgba(250,250,250,0.85); }
.nav-links a:hover { color: var(--yellow); }
.nav-tel {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 14px;
  background: var(--phone-blue);
  color: #fff !important;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  box-shadow: 0 2px 12px rgba(37,99,235,0.35);
  border-radius: 2px;
  transition: background 0.2s;
}
.nav-tel:hover { background: var(--phone-blue-hover); }

@media (max-width: 760px) {
  .vm-nav { padding: 10px 14px; }
  .logo img { height: 28px; }
  .logo-text { display: none; }
  .nav-links { display: none; }
  .nav-tel { padding: 9px 12px; }
  .tel-txt { display: none; }
  .nav-tel {
    background: var(--yellow);
    color: var(--bg) !important;
    box-shadow: none;
  }
}
</style>
