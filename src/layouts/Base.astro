---
// Base Layout — pré-renderizado no build (SSG)
interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title = 'VM Estruturas Metálicas — Erguemos galpões. Não vendemos m².',
  description = 'VM Estruturas Metálicas — Fabricação, projeto e montagem de galpões industriais em Barueri/SP. Do mezanino de 50m² ao galpão de 5.000m². Entrega em 120 dias.',
  image = 'https://vmmanutencaoindustrial-create.github.io/vm-estruturas-fluido/assets/vm-obras/vm-fachada.jpg'
} = Astro.props;

const canonical = 'https://vmmanutencaoindustrial-create.github.io/vm-estruturas-fluido/';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="galpão industrial, estrutura metálica, fabricação galpão, montagem galpão Barueri, NBR 8800, mezanino steel deck, cobertura metálica, ponte rolante" />
  <meta name="author" content="VM Estruturas Metálicas" />
  <meta name="theme-color" content="#FFD700" />
  <meta name="geo.region" content="BR-SP" />
  <meta name="geo.placename" content="Barueri" />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={image} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="VM Estruturas Metálicas" />
  <meta property="og:locale" content="pt_BR" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Icons -->
  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/assets/vm-logo.png`} />
  <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/assets/vm-logo.png`} />

  <!-- Importmap pra 3D lazy (OrbitControls depende de 'three' como bare import) -->
  <script type="importmap" is:inline>
  {
    "imports": {
      "three": "https://cdn.jsdelivr.net/npm/three@0.168.0/build/three.module.js",
      "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.168.0/examples/jsm/"
    }
  }
  </script>

  <!-- Fonts — preconnect + swap pra não bloquear render -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700;800&display=swap" as="style" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700;800&display=swap" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500;700;800&display=swap" />
  </noscript>

  <!-- Preload hero image (LCP) — WebP primeiro com fallback -->
  <link rel="preload" as="image" href={`${import.meta.env.BASE_URL}/assets/vm-obras/vm-fachada.webp`} type="image/webp" fetchpriority="high" />
  <link rel="preload" as="image" href={`${import.meta.env.BASE_URL}/assets/galpao-fase-01.webp`} type="image/webp" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "VM Estruturas Metálicas",
    "alternateName": "VM Manutenção Industrial",
    "description": description,
    "url": canonical,
    "telephone": "+55-11-97232-8541",
    "email": "vmmanutencaoindustrial@gmail.com",
    "image": image,
    "priceRange": "$$$",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Barueri",
      "addressRegion": "SP",
      "addressCountry": "BR"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": -23.5106, "longitude": -46.8761 },
    "areaServed": [{ "@type": "State", "name": "São Paulo" }],
    "openingHoursSpecification": [{
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "07:00",
      "closes": "18:00"
    }],
    "sameAs": ["https://www.instagram.com/vmmanutencaoindustrial"]
  })} />

  <!-- Kill-switch: desregistra qualquer Service Worker antigo que possa interferir -->
  <script is:inline>
    (function () {
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then(function (regs) {
          regs.forEach(function (r) { r.unregister(); });
        }).catch(function () {});
      }
      // Limpa caches antigos do browser (Cache API)
      if ('caches' in window) {
        caches.keys().then(function (keys) {
          keys.forEach(function (k) { caches.delete(k); });
        }).catch(function () {});
      }
    })();
  </script>

  <!-- Scroll progress var (atualiza --progress no <html>) -->
  <script is:inline>
    (function () {
      let ticking = false;
      function update() {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? window.scrollY / max : 0;
        document.documentElement.style.setProperty('--progress', p.toFixed(4));
        document.documentElement.style.setProperty('--scroll-y', window.scrollY + 'px');
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });

      // vh/vw real (resolve bug address-bar iOS)
      function updateVh() {
        document.documentElement.style.setProperty('--vh', (window.innerHeight / 100) + 'px');
        document.documentElement.style.setProperty('--vw', (window.innerWidth / 100) + 'px');
      }
      updateVh();
      window.addEventListener('resize', updateVh, { passive: true });
      window.addEventListener('orientationchange', updateVh, { passive: true });
    })();
  </script>
</head>
<body>
  <slot />

  <!-- WhatsApp sticky mobile (aparece após scroll, some no topo) -->
  <a
    href="https://wa.me/5511972328541?text=Ol%C3%A1!%20Vim%20pelo%20site%20da%20VM%20Estruturas%20Met%C3%A1licas%20e%20quero%20or%C3%A7amento%20de%20galp%C3%A3o."
    target="_blank"
    rel="noopener"
    class="wa-sticky"
    aria-label="Falar no WhatsApp com VM Estruturas"
    id="waSticky"
  >
    <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" fill="#0a0a0a">
      <path d="M20.5 3.5A11 11 0 0 0 3.6 17.3L2 22l4.8-1.6A11 11 0 1 0 20.5 3.5Zm-8.5 17a9.1 9.1 0 0 1-4.7-1.3l-.3-.2-3 1 1-2.9-.2-.3a9.1 9.1 0 1 1 7.2 3.6Zm5-6.8c-.3-.1-1.6-.8-1.9-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.2.2-.3.2-.6.1a7.5 7.5 0 0 1-3.7-3.3c-.3-.5.3-.5.8-1.5 0-.2 0-.3-.1-.5l-.9-2c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5 0-.7.3a2.6 2.6 0 0 0-.9 2c0 1.2.9 2.3 1 2.5l2.1 3.2a9.7 9.7 0 0 0 3.8 2.5c.5.2.9.3 1.3.4.5.1 1 .1 1.4 0 .4-.1 1.3-.5 1.5-1 .2-.6.2-1 .1-1.1 0-.2-.2-.2-.5-.3Z"/>
    </svg>
    <span class="wa-sticky-txt mono">ORÇAMENTO</span>
  </a>

  <script is:inline>
    // Show sticky after scroll > 400
    (() => {
      const el = document.getElementById('waSticky');
      if (!el) return;
      const onScroll = () => {
        el.classList.toggle('show', window.scrollY > 400);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>

  <style is:global>
    .wa-sticky {
      position: fixed;
      bottom: calc(16px + env(safe-area-inset-bottom));
      right: 16px;
      z-index: 9000;
      display: none;
      align-items: center;
      gap: 8px;
      padding: 12px 18px 12px 14px;
      background: #25D366;
      color: #0a0a0a;
      border-radius: 999px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.45), 0 0 0 2px rgba(255,255,255,0.06) inset;
      font-weight: 800;
      letter-spacing: 0.08em;
      font-size: 0.72rem;
      text-transform: uppercase;
      transform: translateY(6px);
      opacity: 0;
      transition: opacity .25s ease, transform .25s ease;
      min-height: 48px;
    }
    .wa-sticky.show { display: inline-flex; opacity: 1; transform: translateY(0); }
    .wa-sticky:hover { background: #20bd5b; transform: translateY(-2px); }
    .wa-sticky:focus-visible { outline: 3px solid var(--yellow); outline-offset: 3px; }
    @media (max-width: 500px) {
      .wa-sticky { padding: 12px 14px; }
      .wa-sticky-txt { display: none; }
    }
    @media print { .wa-sticky { display: none !important; } }
  </style>
</body>
</html>
